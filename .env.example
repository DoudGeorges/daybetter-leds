# BLE MAC address of the LED strip (found via nRF Connect or similar scanner).
BLE_ADDRESS=AA:BB:CC:DD:EE:FF

# Device GATT profile key (see PROTOCOL.md § Device Profiles).
BLE_PROFILE=P031

# IP address of the Raspberry Pi running relay.py.
RELAY_HOST=192.168.1.100

# UDP port shared between capture.py and relay.py.
RELAY_PORT=9000
